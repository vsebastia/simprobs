RewriteEngine On

# Canonicaliza todas las señales SEO en una única URL pública.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.problabtools\.es$ [NC]
RewriteRule ^ https://problabtools.es%{REQUEST_URI} [R=301,L,NE]

RewriteRule ^index\.html$ / [R=301,L]

<IfModule mod_headers.c>
  <FilesMatch "\.(?:html?)$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(?:css|js|png|svg|webp|jpg|jpeg|gif|ico|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset Pragma
    Header unset Expires
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>
